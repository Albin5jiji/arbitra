PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CONTRACT_ADDRESS=0xYourDeployedPayGuardAddress
PRIVATE_KEY=0xYourOwnerWalletPrivateKey

# AI_PROVIDER can be openai, anthropic, or mock.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# x402 uses Base Sepolia's public facilitator by default.
# Set X402_NETWORK=eip155:10143 with a facilitator that supports Monad testnet.
X402_NETWORK=eip155:84532
X402_PRICE=$0.01
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAY_TO=0xYourReceivingWallet
